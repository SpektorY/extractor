# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hamachletz

# Security - generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=1440
MAGIC_LINK_EXPIRE_MINUTES=1440

# CORS (comma-separated or single origin)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend URL (for magic links in WhatsApp)
FRONTEND_BASE_URL=http://localhost:5173

# Optional: WhatsApp (Twilio)
# WHATSAPP_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+1234567890

# Optional: WhatsApp (GreenAPI)
# WHATSAPP_PROVIDER=greenapi
# GREENAPI_INSTANCE_ID=
# GREENAPI_TOKEN=

# Optional: Password reset email (leave unset for stub — no email sent)
# EMAIL_BACKEND=smtp   # or resend
# EMAIL_FROM=noreply@yourdomain.com
# EMAIL_FROM_NAME=המחלץ
# SMTP (when EMAIL_BACKEND=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true
# Resend (when EMAIL_BACKEND=resend): https://resend.com
# RESEND_API_KEY=re_xxxx

# Optional: Debug
# DEBUG=false
